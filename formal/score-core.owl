    </rdf:Description>

    <!-- General class axiom (GCI): operating any morphism requires a B2 or B3
         constituent. There is no intra-B1 morphism, so a cycle that performs a
         morphism cannot be constituent-closed in B1. Combined with PureB1Cycle's
         allValuesFrom B1 and the B1/B2/B3 disjointness above, a reasoner derives
         that PureB1Cycle and Actor are disjoint. Mirrors B2Incidence / ActorTypes
         and the morphism-operation requirement in formal/Formal/Score/Core.lean.
         Reasoner-verified with HermiT (Protege, 2026-05-30): ontology consistent;
         (Actor and PureB1Cycle) classified equivalent to owl:Nothing via this GCI
         plus the B1/B2/B3 disjointness, with no other class made unsatisfiable. -->
    <owl:Restriction>
        <owl:onProperty rdf:resource="http://score-theory.org/core#performsMorphism"/>
        <owl:someValuesFrom rdf:resource="http://score-theory.org/core#Morphism"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://score-theory.org/core#hasConstituentDomain"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://score-theory.org/core#B2_Subjective"/>
                            <rdf:Description rdf:about="http://score-theory.org/core#B3_Inscription"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Restriction>

    <!-- Referent typing of the Inscription morphism (foundational, 2026-06-04).
         carriedBy = token-level realization (every B3 object is a B1 mark; realization,
         not reduction — multiply realizable). The referent GCI = performing B2-referential
         inscription entails the actor has SufficientDepth (the human differentia gate).
         See domains/B3-Inscription.md and morphisms/Morphisms.md. -->
    <owl:ObjectProperty rdf:about="http://score-theory.org/core#carriedBy">
        <rdfs:domain rdf:resource="http://score-theory.org/core#B3_Inscription"/>
        <rdfs:range rdf:resource="http://score-theory.org/core#B1_Objective"/>
        <rdfs:comment>Token-level realization: every B3 inscription object is carried by (realized as) a B1 mark. Realization, not reduction.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:Class rdf:about="http://score-theory.org/core#B3_Inscription">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://score-theory.org/core#carriedBy"/>
                <owl:someValuesFrom rdf:resource="http://score-theory.org/core#B1_Objective"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Referent GCI: performing B2-referential inscription requires sufficient reflexive
         depth. Reflexive depth is a B2-grounded scale, so this also keeps B2-referential
         inscription out of the not-B2-grounded Omega-actor. -->
    <owl:Restriction>
        <owl:onProperty rdf:resource="http://score-theory.org/core#performsInscription"/>
        <owl:someValuesFrom rdf:resource="http://score-theory.org/core#B2ReferentialInscription"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://score-theory.org/core#hasReflexiveDepth"/>
                <owl:someValuesFrom rdf:resource="http://score-theory.org/core#SufficientDepth"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Restriction>
</rdf:RDF>



