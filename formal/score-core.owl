        <rdfs:range rdf:resource="http://score-theory.org/core#CoInscriptionEvent"/>
    </owl:ObjectProperty>
    


    <!-- http://score-theory.org/core#hasHOA -->

    <owl:ObjectProperty rdf:about="http://score-theory.org/core#hasHOA">
        <rdfs:domain rdf:resource="http://score-theory.org/core#HumanCommunity"/>
