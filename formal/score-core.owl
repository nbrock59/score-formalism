    </owl:ObjectProperty>



    <!-- http://score-theory.org/core#hasStabilizationProperty -->

    <owl:ObjectProperty rdf:about="http://score-theory.org/core#hasStabilizationProperty">
        <rdfs:domain rdf:resource="http://score-theory.org/core#HOA"/>
        <rdfs:range rdf:resource="http://score-theory.org/core#SelfStabilizationProperty"/>
        <rdfs:comment>The stabilization property (if any) exhibited by an HOA. For SCORE HOAs, this is WithinBasinConvergence — self-stabilization is guaranteed within the hysteresis basin, not globally. See obsidian/sources/Dijkstra-Edsger.md. Lean: SelfStabilizingWithin (formal/Formal/Score/SelfStabilization.lean).</rdfs:comment>
    </owl:ObjectProperty>



